# Firebase Configuration (optionnel, car configuré via fichiers natifs)
# Mais peut être utilisé pour d'autres variables d'environnement

# API Keys (if needed)
# API_KEY=your_api_key_here

# Environment
NODE_ENV=development

# App Configuration
APP_NAME=Mamadina
APP_VERSION=1.0.0

# Backend URL (si backend personnalisé)
# API_URL=https://api.mamadina.com

# Google Maps API Key (si nécessaire)
# GOOGLE_MAPS_API_KEY=your_google_maps_key
